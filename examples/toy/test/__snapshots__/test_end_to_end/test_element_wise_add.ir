    %loop_header4 : Nil = goto.region([index.Index(0)]) body<%self: goto.Label, %exit4: goto.Label>(%i4: index.Index) captures(%4, %5, %6):
        %loop_body4 : goto.Label = goto.label([]) body(%7: index.Index) captures(%self, %exit4, %4, %5, %6):
            %8 : index.Index = algebra.add(%7, index.Index(1))
            %loop_header5 : Nil = goto.region([index.Index(0)]) body<%9: goto.Label, %exit5: goto.Label>(%i5: index.Index) captures(%4, %5, %6, %7):
                %loop_body5 : goto.Label = goto.label([]) body(%10: index.Index) captures(%9, %exit5, %4, %5, %6, %7):
                    %11 : index.Index = algebra.add(%10, index.Index(1))
                    %12 : memory.Buffer<number.Float64> = llvm.extract_value<index.Index(0)>(%5)
                    %13 : index.Index = algebra.multiply(%7, index.Index(2))
                    %14 : index.Index = algebra.add(%13, %10)
                    %15 : number.Float64 = memory.buffer_load(%5, %12, %14)
                    %16 : memory.Buffer<number.Float64> = llvm.extract_value<index.Index(0)>(%6)
                    %17 : index.Index = algebra.multiply(%7, index.Index(2))
                    %18 : index.Index = algebra.add(%17, %10)
                    %19 : number.Float64 = memory.buffer_load(%6, %16, %18)
                    %20 : number.Float64 = algebra.add(%15, %19)
                    %21 : memory.Buffer<number.Float64> = llvm.extract_value<index.Index(0)>(%4)
                    %22 : index.Index = algebra.multiply(%7, index.Index(2))
                    %23 : index.Index = algebra.add(%22, %10)
