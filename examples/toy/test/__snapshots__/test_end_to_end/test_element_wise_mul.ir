%main : function.Function<[], Nil> = function.function<Nil>() body():
    %0 : function.Function<[llvm.Ptr, index.Index], Nil> = extern<String("print_memref")>()
    %1 : llvm.Ptr = llvm.alloca<index.Index(2)>()
    %2 : function.Function<[index.Index], llvm.Ptr> = extern<String("malloc")>()
    %3 : llvm.Int<index.Index(64)> = llvm.mul(index.Index(4), llvm.Int<index.Index(64)>(8))
    %4 : llvm.Ptr = function.call<%2>([%3])
    %5 : Nil = memory.store(%1, %4, %1)
    %6 : llvm.Ptr = llvm.gep(%1, index.Index(1))
    %7 : Nil = memory.store(%5, index.Index(4), %6)
    %8 : ndbuffer.NDBuffer<ndbuffer.Shape<index.Index(2)>([2, 2]), number.Float64> = memory.load(%7, %1)
    %9 : index.Index = 0
    %10 : toy.Tensor<ndbuffer.Shape<index.Index(2)>([2, 2]), number.Float64> = [1.0, 2.0, 3.0, 4.0]
    %11 : toy.Tensor<ndbuffer.Shape<index.Index(2)>([2, 2]), number.Float64> = [5.0, 6.0, 7.0, 8.0]
    %loop_header2 : Nil = goto.region([%9]) body<%self: goto.Label, %exit2: goto.Label>(%i2: index.Index) captures(%8, %10, %11):
        %loop_body2 : goto.Label = goto.label([]) body(%12: index.Index) captures(%self, %exit2, %8, %10, %11):
            %13 : index.Index = algebra.add(%12, index.Index(1))
            %14 : index.Index = 0
            %loop_header3 : Nil = goto.region([%14]) body<%15: goto.Label, %exit3: goto.Label>(%i3: index.Index) captures(%8, %10, %11, %12):
                %loop_body3 : goto.Label = goto.label([]) body(%16: index.Index) captures(%15, %exit3, %8, %10, %11, %12):
                    %17 : index.Index = algebra.add(%16, index.Index(1))
                    %18 : memory.Reference<number.Float64> = llvm.extract_value<index.Index(0)>(%10)
                    %19 : index.Index = algebra.multiply(%12, index.Index(2))
                    %20 : index.Index = algebra.add(%19, %16)
                    %21 : llvm.Ptr = llvm.gep(%18, %20)
                    %22 : number.Float64 = memory.load(%10, %21)
                    %23 : memory.Reference<number.Float64> = llvm.extract_value<index.Index(0)>(%11)
                    %24 : index.Index = algebra.multiply(%12, index.Index(2))
                    %25 : index.Index = algebra.add(%24, %16)
                    %26 : llvm.Ptr = llvm.gep(%23, %25)
                    %27 : number.Float64 = memory.load(%11, %26)
                    %28 : number.Float64 = algebra.multiply(%22, %27)
                    %29 : memory.Reference<number.Float64> = llvm.extract_value<index.Index(0)>(%8)
                    %30 : index.Index = algebra.multiply(%12, index.Index(2))
                    %31 : index.Index = algebra.add(%30, %16)
                    %32 : llvm.Ptr = llvm.gep(%29, %31)
                    %33 : Nil = memory.store(%28, %28, %32)
                    %34 : index.Index = chain(%17, %33)
                    %35 : Nil = goto.branch<%15>([%34])

                %36 : number.Boolean = algebra.less_than(%i3, index.Index(2))
                %37 : Nil = goto.conditional_branch<%loop_body3, %exit3>(%36, [%i3], [])

            %38 : index.Index = chain(%13, %loop_header3)
            %39 : Nil = goto.branch<%self>([%38])

        %40 : number.Boolean = algebra.less_than(%i2, index.Index(2))
        %41 : Nil = goto.conditional_branch<%loop_body2, %exit2>(%40, [%i2], [])

    %42 : ndbuffer.NDBuffer<ndbuffer.Shape<index.Index(2)>([2, 2]), number.Float64> = chain(%8, %loop_header2)
    %43 : memory.Reference<number.Float64> = llvm.extract_value<index.Index(0)>(%42)
    %44 : Nil = function.call<%0>([%43, index.Index(4)])
