from builtin import list, F64

op constant(value: list[F64]) -> F64Tensor:
    """Constant operation turns a literal into an SSA value.

    The data is attached to the operation as a constant. For example:

    ```ir
    %data: list[F64] = [1.0, 2.0]
    %tensor: F64Tensor = constant(%data)
    ```
    """

    builder (value: double)
    builder (value: DenseElements)

op print(value: F64Tensor) -> None:
    ...
