from builtin import Index, Nil, F64, Array, Pointer

type Shape<rank: Index>:
    dims: Array<Index, rank>

type Reference<shape: Shape, dtype: Type = F64>:
    data: Pointer<Nil>

op alloc(shape: Shape) -> Reference
op dealloc(input: Reference) -> Nil
op load(reference: Reference, indices: Index) -> F64
op store(value: F64, reference: Reference, indices: Index) -> Nil
op print_memref(input: Reference) -> Nil
