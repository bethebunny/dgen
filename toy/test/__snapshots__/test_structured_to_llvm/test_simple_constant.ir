import function
import index
import llvm
import memory
import ndbuffer
import number
import toy

%main : function.Function<[], Nil> = function.function<Nil>() body():
    %0 : toy.Tensor<ndbuffer.Shape<1>([3]), number.Float64> = [1.0, 2.0, 3.0]
    %1 : memory.Reference<number.Float64> = memory.load(%0, %0)
    %2 : index.Index = 3
    %3 : Nil = llvm.call<"print_memref">([%1, %2])
