import function
import index
import llvm
import memory
import ndbuffer
import number
import toy

%main : function.Function<[], Nil> = function.function<Nil>() body():
    %0 : function.Function<[llvm.Ptr, index.Index], Nil> = extern<"print_memref">()
    %1 : toy.Tensor<ndbuffer.Shape<1>([3]), number.Float64> = [1.0, 2.0, 3.0]
    %2 : memory.Reference<number.Float64> = memory.load(%1, %1)
    %3 : index.Index = 3
    %4 : Nil = function.call<%0>([%2, %3])
