import affine
import toy

%main : Nil = function<Nil>() body():
    %0 : affine.MemRef<affine.Shape<2>([2, 2]), F64> = affine.alloc(affine.Shape<2>([2, 2]))
    %1 : toy.Tensor<affine.Shape<2>([2, 2]), F64> = [1.0, 2.0, 3.0, 4.0]
    %2 : affine.MemRef<affine.Shape<2>([2, 2]), F64> = chain(%0, %1)
    %3 : toy.Tensor<affine.Shape<2>([2, 2]), F64> = [5.0, 6.0, 7.0, 8.0]
    %4 : affine.MemRef<affine.Shape<2>([2, 2]), F64> = chain(%2, %3)
    %5 : Nil = affine.for<0, 2>() body(%6: Index):
        %7 : Nil = affine.for<0, 2>() body(%8: Index, %6: Index):
            %9 : F64 = affine.load(%1, [%6, %8])
            %10 : F64 = affine.load(%3, [%6, %8])
            %11 : F64 = affine.add_f(%9, %10)
            %12 : Nil = affine.store(%11, %0, [%6, %8])
    %13 : affine.MemRef<affine.Shape<2>([2, 2]), F64> = chain(%4, %5)
    %14 : Nil = affine.print_memref(%13)
