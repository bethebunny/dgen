import affine
import control_flow
import function
import memory
import toy

%main : Nil = function.define<Nil>() body():
    %0 : memory.MemRef<memory.Shape<2>([2, 2]), F64> = memory.alloc(memory.Shape<2>([2, 2]))
    %1 : toy.Tensor<memory.Shape<2>([2, 2]), F64> = [1.0, 2.0, 3.0, 4.0]
    %2 : memory.MemRef<memory.Shape<2>([2, 2]), F64> = chain(%0, %1)
    %3 : toy.Tensor<memory.Shape<2>([2, 2]), F64> = [5.0, 6.0, 7.0, 8.0]
    %4 : memory.MemRef<memory.Shape<2>([2, 2]), F64> = chain(%2, %3)
    %5 : Nil = control_flow.for<0, 2>([]) body(%6: Index):
        %7 : Nil = control_flow.for<0, 2>([%6]) body(%8: Index, %6: Index):
            %9 : F64 = memory.load(%1, [%6, %8])
            %10 : F64 = memory.load(%3, [%6, %8])
            %11 : F64 = affine.add_f(%9, %10)
            %12 : Nil = memory.store(%11, %0, [%6, %8])
    %13 : memory.MemRef<memory.Shape<2>([2, 2]), F64> = chain(%4, %5)
    %14 : Nil = memory.print_memref(%13)
