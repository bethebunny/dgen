import function
import index
import ndbuffer
import number
import toy

%f : function.Function<[], Nil> = function.function<Nil>() body():
    %1 : index.Index = 4
    %0 : toy.Tensor<ndbuffer.Shape<1>([3]), number.Float64> = [1.0, 2.0, 3.0]
    %2 : toy.Tensor<ndbuffer.Shape<2>([4, 3]), number.Float64> = toy.tile<%1>(%0)
    %3 : Nil = toy.print(%2)
