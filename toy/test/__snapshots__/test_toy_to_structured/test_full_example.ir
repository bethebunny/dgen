import algebra
import control_flow
import function
import index
import ndbuffer
import number

%main : function.Function<()> = function.function<Nil>() body():
    %0 : ndbuffer.NDBuffer<ndbuffer.Shape<2>([3, 2]), number.Float64> = ndbuffer.alloc(ndbuffer.Shape<2>([3, 2]))
    %1 : Nil = control_flow.for<0, 3>([]) body(%2: index.Index) captures(%0, %11, %12):
        %3 : Nil = control_flow.for<0, 2>([]) body(%4: index.Index) captures(%0, %11, %12, %2):
            %5 : number.Float64 = ndbuffer.load(%11, [%2, %4])
            %6 : number.Float64 = ndbuffer.load(%12, [%2, %4])
            %7 : number.Float64 = algebra.multiply(%5, %6)
            %8 : Nil = ndbuffer.store(%7, %0, [%2, %4])
    %9 : ndbuffer.NDBuffer<ndbuffer.Shape<2>([3, 2]), number.Float64> = chain(%0, %1)
    %10 : Nil = ndbuffer.print_memref(%9)
