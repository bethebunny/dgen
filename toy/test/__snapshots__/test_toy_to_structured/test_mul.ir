import algebra
import control_flow
import function
import index
import memory
import ndbuffer
import number
import toy

%main : function.Function<()> = function.function<Nil>() body():
    %0 : index.Index = 4
    %1 : ndbuffer.NDBuffer<ndbuffer.Shape<2>([2, 2]), number.Float64> = memory.heap_allocate<number.Float64>(%0)
    %2 : toy.Tensor<ndbuffer.Shape<2>([2, 2]), number.Float64> = [1.0, 2.0, 3.0, 4.0]
    %3 : toy.Tensor<ndbuffer.Shape<2>([2, 2]), number.Float64> = [5.0, 6.0, 7.0, 8.0]
    %4 : Nil = control_flow.for<0, 2>([]) body(%5: index.Index) captures(%1, %2, %3):
        %6 : Nil = control_flow.for<0, 2>([]) body(%7: index.Index) captures(%1, %2, %3, %5):
            %8 : number.Float64 = ndbuffer.load(%2, %2, [%5, %7])
            %9 : number.Float64 = ndbuffer.load(%3, %3, [%5, %7])
            %10 : number.Float64 = algebra.multiply(%8, %9)
            %11 : Nil = ndbuffer.store(%10, %10, %1, [%5, %7])
    %12 : ndbuffer.NDBuffer<ndbuffer.Shape<2>([2, 2]), number.Float64> = chain(%1, %4)
    %13 : Nil = ndbuffer.print_memref(%12)
