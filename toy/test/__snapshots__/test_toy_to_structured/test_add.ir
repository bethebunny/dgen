import algebra
import control_flow
import function
import index
import ndbuffer
import number
import toy

%main : function.Function<()> = function.function<Nil>() body():
    %0 : ndbuffer.NDBuffer<ndbuffer.Shape<2>([2, 2]), number.Float64> = ndbuffer.alloc(ndbuffer.Shape<2>([2, 2]))
    %1 : toy.Tensor<ndbuffer.Shape<2>([2, 2]), number.Float64> = [1.0, 2.0, 3.0, 4.0]
    %2 : toy.Tensor<ndbuffer.Shape<2>([2, 2]), number.Float64> = [5.0, 6.0, 7.0, 8.0]
    %3 : Nil = control_flow.for<0, 2>([]) body(%4: index.Index) captures(%0, %1, %2):
        %5 : Nil = control_flow.for<0, 2>([]) body(%6: index.Index) captures(%0, %1, %2, %4):
            %7 : number.Float64 = ndbuffer.load(%1, %1, [%4, %6])
            %8 : number.Float64 = ndbuffer.load(%2, %2, [%4, %6])
            %9 : number.Float64 = algebra.add(%7, %8)
            %10 : Nil = ndbuffer.store(%9, %9, %0, [%4, %6])
    %11 : ndbuffer.NDBuffer<ndbuffer.Shape<2>([2, 2]), number.Float64> = chain(%0, %3)
    %12 : Nil = ndbuffer.print_memref(%11)
