import algebra
import control_flow
import function
import index
import ndbuffer
import toy

%main : function.Function<()> = function.function<Nil>() body():
    %0 : ndbuffer.NDBuffer<ndbuffer.Shape<2>([2, 2]), number.Float64> = ndbuffer.alloc(ndbuffer.Shape<2>([2, 2]))
    %1 : Nil = control_flow.for<0, 2>([]) body(%2: index.Index):
        %3 : Nil = control_flow.for<0, 2>([%2]) body(%4: index.Index, %2: index.Index):
            %5 : toy.Tensor<ndbuffer.Shape<2>([2, 2]), number.Float64> = [1.0, 2.0, 3.0, 4.0]
            %6 : number.Float64 = ndbuffer.load(%5, [%2, %4])
            %7 : toy.Tensor<ndbuffer.Shape<2>([2, 2]), number.Float64> = [5.0, 6.0, 7.0, 8.0]
            %8 : number.Float64 = ndbuffer.load(%7, [%2, %4])
            %9 : number.Float64 = algebra.add(%6, %8)
            %10 : Nil = ndbuffer.store(%9, %0, [%2, %4])
    %11 : ndbuffer.NDBuffer<ndbuffer.Shape<2>([2, 2]), number.Float64> = chain(%0, %1)
    %12 : Nil = ndbuffer.print_memref(%11)
