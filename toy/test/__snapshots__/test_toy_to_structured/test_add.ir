import algebra
import control_flow
import function
import index
import memory
import toy

%main : function.Function<()> = function.function<Nil>() body():
    %0 : memory.MemRef<memory.Shape<2>([2, 2]), F64> = memory.alloc(memory.Shape<2>([2, 2]))
    %1 : Nil = control_flow.for<0, 2>([]) body(%2: index.Index):
        %3 : Nil = control_flow.for<0, 2>([%2]) body(%4: index.Index, %2: index.Index):
            %5 : toy.Tensor<memory.Shape<2>([2, 2]), F64> = [1.0, 2.0, 3.0, 4.0]
            %6 : F64 = memory.load(%5, [%2, %4])
            %7 : toy.Tensor<memory.Shape<2>([2, 2]), F64> = [5.0, 6.0, 7.0, 8.0]
            %8 : F64 = memory.load(%7, [%2, %4])
            %9 : F64 = algebra.add(%6, %8)
            %10 : Nil = memory.store(%9, %0, [%2, %4])
    %11 : memory.MemRef<memory.Shape<2>([2, 2]), F64> = chain(%0, %1)
    %12 : Nil = memory.print_memref(%11)
