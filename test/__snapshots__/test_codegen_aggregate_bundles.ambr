# serializer version: 1
# name: test_call_with_heterogeneous_tuple_args
  '''
  
  define i64 @first(i64 %a, double %b) {
  entry:
    ret i64 %a
  }
  define i64 @main(i64 %x, double %y) {
  entry:
    %_1 = insertvalue { i64, double } undef, i64 %x, 0
    %_0 = insertvalue { i64, double } %_1, double %y, 1
    %_2 = extractvalue { i64, double } %_0, 0
    %_3 = extractvalue { i64, double } %_0, 1
    %r = call i64 @first(i64 %_2, double %_3)
    ret i64 %r
  }
  '''
# ---
# name: test_call_with_runtime_tuple_as_args
  '''
  
  define i64 @add(i64 %a, i64 %b) {
  entry:
    %_0 = add i64 %a, %b
    ret i64 %_0
  }
  define i64 @main(i64 %x, i64 %y) {
  entry:
    %_2 = insertvalue { i64, i64 } undef, i64 %x, 0
    %_1 = insertvalue { i64, i64 } %_2, i64 %y, 1
    %_3 = extractvalue { i64, i64 } %_1, 0
    %_4 = extractvalue { i64, i64 } %_1, 1
    %r = call i64 @add(i64 %_3, i64 %_4)
    ret i64 %r
  }
  '''
# ---
# name: test_inline_pack_call
  '''
  
  define i64 @add(i64 %a, i64 %b) {
  entry:
    %_0 = add i64 %a, %b
    ret i64 %_0
  }
  define i64 @main(i64 %x, i64 %y) {
  entry:
    %_2 = insertvalue { i64, i64 } undef, i64 %x, 0
    %_1 = insertvalue { i64, i64 } %_2, i64 %y, 1
    %_3 = extractvalue { i64, i64 } %_1, 0
    %_4 = extractvalue { i64, i64 } %_1, 1
    %r = call i64 @add(i64 %_3, i64 %_4)
    ret i64 %r
  }
  '''
# ---
