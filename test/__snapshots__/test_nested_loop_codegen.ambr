  define void @test() {
  entry:
    br label %loop_header0
  loop_header0:
    %i0 = phi i64 [ %3, %loop_body0 ], [ 0, %entry ]
    %5 = icmp slt i64 %i0, 2
    br i1 %5, label %loop_body0, label %exit0
  loop_body0:
    %j0 = phi i64 [ %i0, %loop_header0 ]
    br label %loop_header1
  loop_header1:
    %i1 = phi i64 [ %17, %loop_body1 ], [ 0, %loop_body0 ]
    %19 = icmp slt i64 %i1, 2
    br i1 %19, label %loop_body1, label %exit1
  loop_body1:
    %j1 = phi i64 [ %i1, %loop_header1 ]
    %17 = add i64 %j1, 1
    br label %loop_header1
  exit1:
    %3 = add i64 %j0, 1
    br label %loop_header0
  exit0:
  }
