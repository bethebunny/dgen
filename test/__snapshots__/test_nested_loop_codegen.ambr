# serializer version: 1
# name: test_nested_loop_llvm_ir
  '''
  declare void @print_memref(ptr, i64)
  declare ptr @malloc(i64)
  
  define void @test() {
  entry:
    br label %loop_header0
  loop_header0:
    %i0 = phi i64 [ %25, %loop_body0 ], [ 0, %entry ]
    %4 = icmp slt i64 %i0, 2
    br i1 %4, label %loop_body0, label %exit0
  loop_body0:
    %j0 = phi i64 [ %i0, %loop_header0 ]
    br label %loop_header1
  loop_header1:
    %i1 = phi i64 [ %20, %loop_body1 ], [ 0, %loop_body0 ]
    %13 = icmp slt i64 %i1, 2
    br i1 %13, label %loop_body1, label %exit1
  loop_body1:
    %j1 = phi i64 [ %i1, %loop_header1 ]
    %20 = add i64 %j1, 1
    br label %loop_header1
    ret void
    ret void
  exit1:
    %25 = add i64 %j0, 1
    br label %loop_header0
    ret void
  exit0:
    ret void
  }
  '''
# ---
