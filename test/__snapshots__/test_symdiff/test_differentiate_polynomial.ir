import algebra
import function
import number

%main : function.Function<[number.Float64], number.Float64> = function.function<number.Float64>() body(%x: number.Float64):
    %three : number.Float64 = 3.0
    %0 : number.Float64 = algebra.multiply(%three, number.Float64(1.0))
    %1 : number.Float64 = algebra.multiply(%x, number.Float64(1.0))
    %2 : number.Float64 = algebra.add(%0, %1)
    %3 : number.Float64 = algebra.multiply(%x, number.Float64(1.0))
    %4 : number.Float64 = algebra.add(%2, %3)
