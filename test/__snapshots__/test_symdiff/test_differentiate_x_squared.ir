import algebra
import function
import number

%f : function.Function<[number.Float64], number.Float64> = function.function<number.Float64>() body(%x: number.Float64):
    %0 : number.Float64 = algebra.multiply(%x, number.Float64(1.0))
    %1 : number.Float64 = algebra.multiply(%x, number.Float64(1.0))
    %2 : number.Float64 = algebra.add(%0, %1)
