import algebra
import function
import number

%grad_f : function.Function<[number.Float64, number.Float64], Span<number.Float64>> = function.function<Span<number.Float64>>() body(%x: number.Float64, %y: number.Float64):
    %0 : number.Float64 = algebra.multiply(%y, number.Float64(1.0))
    %1 : number.Float64 = algebra.add(number.Float64(1.0), %0)
    %2 : number.Float64 = algebra.multiply(%x, number.Float64(1.0))
