import algebra
import function
import number

%grad_f : function.Function<[number.Float64], number.Float64> = function.function<number.Float64>() body(%x: number.Float64):
    %0 : number.Float64 = algebra.multiply(%x, number.Float64(1.0))
    %1 : number.Float64 = algebra.multiply(%x, number.Float64(1.0))
    %2 : number.Float64 = algebra.add(%0, %1)

%main : function.Function<[number.Float64], number.Float64> = function.function<number.Float64>() body(%3: number.Float64) captures(%grad_f):
    %result : number.Float64 = function.call(%grad_f, [%3])
