import algebra
import function
import goto
import index
import number

%main : function.Function<[index.Index], index.Index> = function.function<index.Index>() body(%n: index.Index):
    %cond : number.Boolean = algebra.equal(%n, 0)
    %if0 : index.Index = goto.region([]) body<%self: goto.Label>(%if_result0: index.Index) captures(%cond, %0, %1):
        %if_then0 : goto.Label = goto.label([]) body() captures(%self):
            %ten : index.Index = 10
            %2 : Nil = goto.branch<%self>([%ten])
        %if_else0 : goto.Label = goto.label([]) body() captures(%self):
            %twenty : index.Index = 20
            %3 : Nil = goto.branch<%self>([%twenty])
        %4 : Nil = goto.conditional_branch<%if_then0, %if_else0>(%cond, [], [])
        %5 : index.Index = chain(%if_result0, %4)
