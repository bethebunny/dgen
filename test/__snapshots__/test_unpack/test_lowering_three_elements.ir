import algebra
import goto
import index
import record

%t : Tuple<[index.Index, index.Index, index.Index]> = record.pack([index.Index(1), index.Index(2), index.Index(3)])
%r : index.Index = goto.region(%t) body<%_: goto.Label, %r_exit: goto.Label>(%x: index.Index, %y: index.Index, %z: index.Index):
    %xy : index.Index = algebra.add(%x, %y)
    %sum : index.Index = algebra.add(%xy, %z)
