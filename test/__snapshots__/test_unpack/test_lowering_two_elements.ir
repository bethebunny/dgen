import algebra
import goto
import index
import record

%a : index.Index = 10
%b : index.Index = 20
%t : Tuple<[index.Index, index.Index]> = record.pack([%a, %b])
%r : index.Index = goto.region([]) body<%_: goto.Label, %r_exit: goto.Label>() captures(%t):
    %x : index.Index = record.get<index.Index(0)>(%t)
    %y : index.Index = record.get<index.Index(1)>(%t)
    %sum : index.Index = algebra.add(%x, %y)
