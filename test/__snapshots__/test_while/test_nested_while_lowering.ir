import algebra
import goto
import index
import number
import record

%while_header0 : Nil = goto.region([index.Index(0)]) body<%self: goto.Label, %exit0: goto.Label>(%wh0_i: index.Index):
    %while_body0 : goto.Label = goto.label([]) body(%wb0_oi: index.Index) captures(%self, %exit0):
        %one : index.Index = 1
        %next : index.Index = algebra.add(%wb0_oi, %one)
        %while_header1 : Nil = goto.region([index.Index(0)]) body<%0: goto.Label, %exit1: goto.Label>(%wh1_j: index.Index):
            %while_body1 : goto.Label = goto.label([]) body(%wb1_j2: index.Index) captures(%0, %exit1):
                %icarry : Tuple<[index.Index]> = record.pack([index.Index(0)])
                %1 : Nil = goto.branch<%0>(%icarry)

            %jtwo : index.Index = 2
            %jcmp : number.Boolean = algebra.less_than(%wh1_j, %jtwo)
            %2 : Nil = goto.conditional_branch<%while_body1, %exit1>(%jcmp, [%wh1_j], [])

        %next2 : index.Index = chain(%next, %while_header1)
        %ocarry : Tuple<[index.Index]> = record.pack([%next2])
        %3 : Nil = goto.branch<%self>(%ocarry)

    %two : index.Index = 2
    %cmp : number.Boolean = algebra.less_than(%wh0_i, %two)
    %4 : Nil = goto.conditional_branch<%while_body0, %exit0>(%cmp, [%wh0_i], [])
