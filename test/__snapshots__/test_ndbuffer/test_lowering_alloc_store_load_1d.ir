%main : function.Function<[number.Float64], number.Float64> = function.function<number.Float64>() body(%x: number.Float64):
    %0 : memory.Buffer<number.Float64> = memory.buffer_allocate<number.Float64>(index.Index(3))
    %1 : ndbuffer.NDBuffer<ndbuffer.Shape<index.Index(1)>([3]), number.Float64> = record.pack([%0, index.Index(3)])
    %2 : memory.Buffer<number.Float64> = record.get<index.Index(0)>(%1)
    %3 : Nil = memory.buffer_store(%1, %2, index.Index(0), %x)
    %4 : memory.Buffer<number.Float64> = record.get<index.Index(0)>(%1)
    %5 : number.Float64 = memory.buffer_load(%3, %4, index.Index(0))
