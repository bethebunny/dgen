    %3 : index.Index = algebra.multiply(index.Index(1), index.Index(3))
    %4 : index.Index = algebra.add(%3, index.Index(2))
    %5 : Nil = memory.buffer_store(%1, %2, %4, %x)
    %6 : memory.Buffer<number.Float64> = record.get<index.Index(0)>(%1)
    %7 : index.Index = algebra.multiply(index.Index(1), index.Index(3))
    %8 : index.Index = algebra.add(%7, index.Index(2))
    %9 : number.Float64 = memory.buffer_load(%5, %6, %8)
