import algebra
import function
import index
import memory
import ndbuffer
import number
import record

%main : function.Function<[number.Float64, number.Float64], number.Float64> = function.function<number.Float64>() body(%x: number.Float64, %y: number.Float64):
    %0 : memory.Buffer<number.Float64> = memory.buffer_allocate<number.Float64>(index.Index(4))
    %1 : ndbuffer.NDBuffer<ndbuffer.Shape<index.Index(1)>([4]), number.Float64> = record.pack([%0, index.Index(4)])
    %2 : memory.Buffer<number.Float64> = record.get<index.Index(0)>(%1)
    %3 : Nil = memory.buffer_store(%1, %2, index.Index(0), %x)
    %4 : memory.Buffer<number.Float64> = record.get<index.Index(0)>(%1)
    %5 : Nil = memory.buffer_store(%3, %4, index.Index(1), %y)
    %6 : memory.Buffer<number.Float64> = record.get<index.Index(0)>(%1)
    %7 : number.Float64 = memory.buffer_load(%5, %6, index.Index(0))
    %8 : memory.Buffer<number.Float64> = record.get<index.Index(0)>(%1)
    %9 : number.Float64 = memory.buffer_load(%5, %8, index.Index(1))
    %result : number.Float64 = algebra.add(%7, %9)
