import c
import function
import index
import memory
import number

%f : function.Function<[memory.Reference<c.CStruct<"S", "S", "S">>], Nil> = function.function<Nil>() body(%s: memory.Reference<c.CStruct<"S", "S", "S">>):
    %0 : memory.Reference<c.CStruct<"S", "S", "S">> = c.lvalue_var<"s">(%s)
    %1 : memory.Reference<c.CStruct<"S", "S", "S">> = c.lvalue_to_rvalue(%0)
    %2 : memory.Reference<number.SignedInteger<32>> = c.field_address<"x">(%1)
    %3 : number.SignedInteger<32> = 7
    %4 : number.SignedInteger<32> = c.store_indirect(%2, %3)
