import algebra
import c
import function
import index
import number

%f : function.Function<[], number.SignedInteger<64>> = function.function<number.SignedInteger<64>>() body():
    %0 : number.SignedInteger<64> = 1
    %1 : number.SignedInteger<64> = 2
    %2 : number.SignedInteger<64> = algebra.add(%0, %1)
    %3 : Nil = c.return(%2)
