import algebra
import c
import function
import index
import memory
import number

%f : function.Function<[memory.Reference<number.SignedInteger<index.Index(32)>>], Nil> = function.function<Nil>() body(%p: memory.Reference<number.SignedInteger<index.Index(32)>>):
    %0 : number.SignedInteger<index.Index(32)> = c.dereference(%p)
    %1 : number.SignedInteger<index.Index(32)> = 1
    %2 : number.SignedInteger<index.Index(32)> = algebra.add(%0, %1)
    %3 : number.SignedInteger<index.Index(32)> = c.store_indirect(%p, %2)
