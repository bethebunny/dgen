import algebra
import c
import function
import index
import memory
import number

%f : function.Function<[memory.Reference<number.SignedInteger<32>>], Nil> = function.function<Nil>() body(%p: memory.Reference<number.SignedInteger<32>>):
    %0 : memory.Reference<number.SignedInteger<32>> = c.lvalue_var<"p">(%p)
    %1 : memory.Reference<number.SignedInteger<32>> = c.lvalue_to_rvalue(%0)
    %2 : number.SignedInteger<32> = c.dereference(%1)
    %3 : number.SignedInteger<32> = 1
    %4 : number.SignedInteger<32> = algebra.add(%2, %3)
    %5 : number.SignedInteger<32> = c.store_indirect(%1, %4)
