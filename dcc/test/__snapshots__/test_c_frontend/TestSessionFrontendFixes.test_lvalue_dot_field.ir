import c
import function
import index
import memory
import number

%f : function.Function<[], Nil> = function.function<Nil>() body():
    %0 : c.CStruct<"S", "S", "S"> = 0
    %1 : c.CStruct<"S", "S", "S"> = c.lvalue_var<"s">(%0)
    %2 : c.CStruct<"S", "S", "S"> = c.lvalue_assign(%1, %0)
    %3 : memory.Reference<c.CStruct<"S", "S", "S">> = c.address_of(%2)
    %4 : memory.Reference<number.SignedInteger<32>> = c.field_address<"x">(%3)
    %5 : number.SignedInteger<32> = 7
    %6 : number.SignedInteger<32> = c.store_indirect(%4, %5)
