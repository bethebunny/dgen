import c
import function
import index
import memory
import number

%f : function.Function<[], Nil> = function.function<Nil>() body():
    %0 : c.CStruct<"S", "S", "S"> = 0
    %1 : c.CStruct<"S", "S", "S"> = c.variable_declaration<"s", c.CStruct<"S", "S", "S">>(%0)
    %2 : memory.Reference<c.CStruct<"S", "S", "S">> = c.address_of(%1)
    %3 : memory.Reference<number.SignedInteger<32>> = c.field_address<"x">(%2)
    %4 : number.SignedInteger<32> = 7
    %5 : number.SignedInteger<32> = c.store_indirect(%3, %4)
