%f : function.Function<[memory.Reference<c.CStruct<"Outer", "Outer", "Outer">>], number.SignedInteger<32>> = function.function<number.SignedInteger<32>>() body(%o: memory.Reference<c.CStruct<"Outer", "Outer", "Outer">>):
    %0 : memory.Reference<c.CStruct<"Fwd", "Fwd", "Fwd">> = c.pointer_member_access<"p">(%o)
    %1 : memory.Reference<Nil> = c.pointer_member_access<"x">(%0)
    %2 : number.SignedInteger<32> = algebra.cast(%1)
    %3 : Nil = c.return(%2)
