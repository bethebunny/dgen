from builtin import Nil

trait AddMagma
trait MulMagma
trait TotalOrder

op add(left, right)
op negate(input)
op subtract(left, right)
op multiply(left, right)
op reciprocal(input)
op divide(left, right)
op meet(left, right)
op join(left, right)
op complement(input)
op symmetric_difference(left, right)
op equal(left, right)
op not_equal(left, right)
op less_than(left, right)
op less_equal(left, right)
op greater_than(left, right)
op greater_equal(left, right)
op cast(input)
