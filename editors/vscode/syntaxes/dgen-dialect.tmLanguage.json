{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "DGEN Dialect",
    "scopeName": "source.dgen",
    "fileTypes": ["dgen"],
    "patterns": [
        {"include": "#comment"},
        {"include": "#from-import"},
        {"include": "#bare-import"},
        {"include": "#trait-decl"},
        {"include": "#type-decl"},
        {"include": "#op-decl"},
        {"include": "#block-decl"},
        {"include": "#has-trait"},
        {"include": "#arrow"},
        {"include": "#type-ref"},
        {"include": "#number"},
        {"include": "#string"},
        {"include": "#punctuation"}
    ],
    "repository": {
        "comment": {
            "name": "comment.line.number-sign.dgen",
            "match": "#.*$"
        },
        "from-import": {
            "match": "^(from)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+(import)\\b",
            "captures": {
                "1": {"name": "keyword.control.import.dgen"},
                "2": {"name": "entity.name.namespace.dgen"},
                "3": {"name": "keyword.control.import.dgen"}
            }
        },
        "bare-import": {
            "match": "^(import)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "captures": {
                "1": {"name": "keyword.control.import.dgen"},
                "2": {"name": "entity.name.namespace.dgen"}
            }
        },
        "trait-decl": {
            "match": "^(trait)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "captures": {
                "1": {"name": "keyword.other.dgen"},
                "2": {"name": "entity.name.type.dgen"}
            }
        },
        "type-decl": {
            "match": "^(type)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "captures": {
                "1": {"name": "keyword.other.dgen"},
                "2": {"name": "entity.name.type.dgen"}
            }
        },
        "op-decl": {
            "match": "^(op)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "captures": {
                "1": {"name": "keyword.other.dgen"},
                "2": {"name": "entity.name.function.dgen"}
            }
        },
        "block-decl": {
            "match": "^\\s+(block)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "captures": {
                "1": {"name": "keyword.other.dgen"},
                "2": {"name": "variable.other.dgen"}
            }
        },
        "has-trait": {
            "match": "\\b(has)\\s+(trait)\\b",
            "captures": {
                "1": {"name": "keyword.other.dgen"},
                "2": {"name": "keyword.other.dgen"}
            }
        },
        "arrow": {
            "name": "keyword.operator.arrow.dgen",
            "match": "->"
        },
        "type-ref": {
            "name": "entity.name.type.dgen",
            "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        "number": {
            "patterns": [
                {
                    "name": "constant.numeric.float.dgen",
                    "match": "\\b[0-9]+\\.[0-9]*([eE][+-]?[0-9]+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.dgen",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "string": {
            "name": "string.quoted.double.dgen",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.dgen",
                    "match": "\\\\."
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {"name": "keyword.operator.dgen", "match": "="},
                {"name": "punctuation.separator.dgen", "match": ","},
                {"name": "punctuation.definition.block.dgen", "match": ":"},
                {"name": "punctuation.bracket.dgen", "match": "[()\\[\\]<>]"}
            ]
        }
    }
}
