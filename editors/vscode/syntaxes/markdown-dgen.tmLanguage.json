{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "scopeName": "markdown.dgen.codeblock",
    "injectionSelector": "L:text.html.markdown",
    "patterns": [{"include": "#fenced-dgen"}],
    "repository": {
        "fenced-dgen": {
            "begin": "(^|\\G)(\\s*)(```+|~~~+)\\s*(?i:(dgen))\\s*$",
            "end": "(^|\\G)(\\2)(\\3)\\s*$",
            "name": "markup.fenced_code.block.markdown",
            "contentName": "meta.embedded.block.dgen",
            "beginCaptures": {
                "3": {"name": "punctuation.definition.fenced.markdown"},
                "4": {"name": "constant.other.language-name.markdown"}
            },
            "endCaptures": {
                "3": {"name": "punctuation.definition.fenced.markdown"}
            },
            "patterns": [{"include": "source.dgen"}]
        }
    }
}
